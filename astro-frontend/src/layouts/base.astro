---
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Sulix.Intel', description = 'Geopolitical Tech Intelligence Briefing' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Sulix.Intel</title>
  <meta name="description" content={description} />
  <meta property="og:site_name" content="Sulix Intelligence" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="stylesheet" href="/design.css">
  <style>
    body { margin: 0; padding: 0; }
    *. { box-sizing: border-box; }
    a { text-decoration: none; color: inherit; }
    a:hover { text-decoration: underline; }
    .font-mono { font-family: 'JetBrains Mono', 'Courier New', monospace; }
    .container { max-width: 72rem; margin: 0 auto; padding: 0 1rem; }
  </style>
</head>
<body>
  <!-- Block A: 顶栏导航 -->
  <header class="border-b border-neutral-100 bg-white">
    <div class="container flex items-center justify-between" style="height:3rem">
      <a href="/" class="flex items-center gap-2" style="text-decoration:none">
        <span class="font-mono font-bold" style="font-size:0.75rem;color:#e3120b">i</span>
        <span class="font-mono font-bold text-neutral-900" style="font-size:0.9375rem">Sulix.Intel</span>
      </a>
      <nav class="flex items-center gap-4">
        <a href="/research" class="font-mono text-xs text-neutral-400 uppercase tracking-wider" style="text-decoration:none">Research</a>
        <a href="/memory" class="font-mono text-xs text-neutral-400 uppercase tracking-wider" style="text-decoration:none">Memory</a>
        <a href="https://sulix.substack.com/subscribe" target="_blank" class="font-mono text-xs font-semibold uppercase tracking-wider" style="color:#e3120b;text-decoration:none">Subscribe →</a>
      </nav>
    </div>
  </header>
  <main class="container" style="padding-top:1.5rem;padding-bottom:2rem">
    <slot />
  </main>
  <!-- Block C: 底座溯源 -->
  <footer class="container" style="padding:1rem 1rem 2rem;border-top:1px solid #e5e5e5;margin-top:1rem">
    <p class="font-mono text-xs text-neutral-400" style="line-height:1.5;margin:0">
      * Sulix operates under Fair Use for independent research. Data sourced from publicly available primary documents.
    </p>
    <p class="font-mono text-xs text-neutral-400 mt-2">
      Sulix.Intel · intel.getsulix.com · Substack · GitHub · MIT
    </p>
  </footer>
</body>
</html>
