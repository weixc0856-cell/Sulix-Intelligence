---
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Sulix.Intel', description = 'Geopolitical Tech Intelligence Briefing' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Sulix.Intel</title>
  <meta name="description" content={description} />
  <meta property="og:site_name" content="Sulix Intelligence" />
  <meta name="twitter:card" content="summary_large_image" />
  <style>
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #fcfcfc; color: #111; margin: 0; padding: 0; -webkit-font-smoothing: antialiased; }
    * { box-sizing: border-box; }
    a { text-decoration: none; color: inherit; }
    a:hover { text-decoration: underline; }
    .font-mono { font-family: 'JetBrains Mono', 'Courier New', monospace; }
    .container { max-width: 72rem; margin: 0 auto; padding: 0 1rem; }
  </style>
</head>
<body>
  <!-- Block A: 顶栏导航 -->
  <header style="border-bottom:1px solid #e5e5e5;background:#fff">
    <div class="container" style="height:3rem;display:flex;align-items:center;justify-content:space-between">
      <a href="/" style="display:flex;align-items:center;gap:0.5rem">
        <span style="background-color:#e3120b;color:#fff;font-family:'JetBrains Mono',monospace;font-weight:700;font-size:0.75rem;padding:0.125rem 0.375rem;border-radius:0.125rem">i</span>
        <span class="font-mono" style="font-weight:700;font-size:0.9375rem;color:#171717">Sulix.Intel</span>
      </a>
      <nav style="display:flex;align-items:center;gap:0.75rem">
        <a href="https://sulix.substack.com/subscribe" target="_blank" style="background-color:#e3120b;color:#fff;font-family:'JetBrains Mono',monospace;font-size:0.625rem;font-weight:600;padding:0.25rem 0.5rem;border-radius:0.125rem;text-transform:uppercase;letter-spacing:0.05em">Subscribe →</a>
      </nav>
    </div>
  </header>
  <main class="container" style="padding-top:1.5rem;padding-bottom:2rem">
    <slot />
  </main>
  <!-- Block C: 底座溯源 -->
  <footer class="container" style="padding-bottom:2rem;border-top:1px solid #e5e5e5;padding-top:1rem">
    <p class="font-mono" style="font-size:0.5625rem;color:#a3a3a3;line-height:1.5;margin:0">
      * Sulix operates under Fair Use for independent research. Data sourced from publicly available primary documents.
    </p>
    <p class="font-mono" style="font-size:0.5625rem;color:#a3a3a3;margin-top:0.5rem">
      Sulix.Intel · intel.getsulix.com · Substack · GitHub · MIT
    </p>
  </footer>
</body>
</html>
