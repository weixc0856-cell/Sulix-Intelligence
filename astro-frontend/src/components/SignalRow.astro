---
export interface Props {
  title: string;
  date: string;
  svi: number;
  colorTag: string;
  isPremium: boolean;
  slug: string;
  summary?: string;
  tags?: string[];
}

const { title, date: postDate, svi, colorTag, isPremium, slug, summary, tags } = Astro.props;
const sviColor = svi >= 9 ? '#dc2626' : svi >= 7 ? '#ea580c' : svi >= 5 ? '#ca8a04' : svi >= 3 ? '#16a34a' : '#2563eb';
---

<div class="signal-row" style="display:flex;flex-direction:column;padding:0.75rem 0;border-bottom:1px solid #e5e5e5">
  <div style="display:flex;align-items:center;gap:0.5rem">
    <span class="font-mono" style="color:{sviColor};font-weight:700;font-size:0.8rem;min-width:3ch">{colorTag} {svi}</span>
    <a href={`/posts/${slug}`} style="font-size:0.875rem;font-weight:500;color:#171717;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{title}</a>
    {isPremium && <span class="font-mono" style="color:#ea580c;font-size:0.65rem;font-weight:600;border:1px solid #ea580c;padding:0.0625rem 0.375rem;border-radius:0.125rem;text-transform:uppercase">🔒 Premium</span>}
  </div>
  {summary && <div style="font-size:0.75rem;color:#525252;margin-top:0.125rem;padding-left:4.5rem">{summary}</div>}
  <div style="font-size:0.625rem;color:#a3a3a3;margin-top:0.125rem;padding-left:4.5rem" class="font-mono">{postDate}</div>
</div>

<style>
  .signal-row:hover { background-color: #f5f5f5; transition: background-color 0.1s ease; }
</style>
