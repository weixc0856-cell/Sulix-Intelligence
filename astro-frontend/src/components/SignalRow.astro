---
export interface Props {
  title: string;
  date: string;
  svi: number;
  colorTag: string;
  isPremium: boolean;
  slug: string;
  summary?: string;
  tags?: string[];
}

const { title, date: postDate, svi, colorTag, isPremium, slug, summary, tags } = Astro.props;
const sviColor = svi >= 9 ? '#dc2626' : svi >= 7 ? '#ea580c' : svi >= 5 ? '#ca8a04' : svi >= 3 ? '#16a34a' : '#2563eb';
---

<div class="signal-row flex flex-col border-b border-neutral-200" style="padding:0.75rem 0">
  <div class="flex items-center gap-2">
    <span class="font-mono font-bold" style="color:{sviColor};font-size:0.8rem;min-width:3ch">{colorTag} {svi}</span>
    <a href={`/posts/${slug}`} class="text-neutral-900 font-semibold" style="font-size:0.875rem;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{title}</a>
    {isPremium && <span class="font-mono font-semibold text-xs uppercase" style="color:#ea580c;border:1px solid #ea580c;padding:0.0625rem 0.375rem;border-radius:0.125rem">🔒 Premium</span>}
  </div>
  {summary && <div class="text-sm text-neutral-500" style="margin-top:0.125rem;padding-left:4.5rem">{summary}</div>}
  <div class="font-mono text-xs text-neutral-400" style="margin-top:0.125rem;padding-left:4.5rem">{postDate}</div>
</div>

<style>
  .signal-row:hover { background-color: #f5f5f5; transition: background-color 0.1s ease; }
</style>
