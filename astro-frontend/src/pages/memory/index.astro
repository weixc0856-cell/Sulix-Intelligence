---
import BaseLayout from '../../layouts/base.astro';
---

<BaseLayout title="Memory | Sulix.Intel" description="Strategic Belief Database">
  <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:0.75rem;padding-bottom:0.5rem;border-bottom:2px solid #171717">
    <h1 class="font-mono" style="font-size:1.25rem;font-weight:700;color:#171717;margin:0">战略记忆</h1>
    <span class="font-mono" id="snapshot-date" style="font-size:0.6875rem;color:#a3a3a3">加载中...</span>
  </div>

  <!-- 概览卡片 -->
  <div id="overview-cards" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(10rem,1fr));gap:0.75rem;margin-bottom:1.5rem">
    <div style="background:#f5f5f5;border-radius:0.25rem;padding:0.75rem;text-align:center">
      <div class="font-mono" style="font-size:0.5625rem;color:#a3a3a3;margin-bottom:0.25rem">顺向证据</div>
      <div id="support-count" style="font-size:1.5rem;font-weight:700;color:#16a34a">—</div>
    </div>
    <div style="background:#f5f5f5;border-radius:0.25rem;padding:0.75rem;text-align:center">
      <div class="font-mono" style="font-size:0.5625rem;color:#a3a3a3;margin-bottom:0.25rem">挑战证据</div>
      <div id="challenge-count" style="font-size:1.5rem;font-weight:700;color:#dc2626">—</div>
    </div>
    <div style="background:#f5f5f5;border-radius:0.25rem;padding:0.75rem;text-align:center">
      <div class="font-mono" style="font-size:0.5625rem;color:#a3a3a3;margin-bottom:0.25rem">矛盾检测</div>
      <div id="contradiction-count" style="font-size:1.5rem;font-weight:700;color:#ea580c">—</div>
    </div>
    <div style="background:#f5f5f5;border-radius:0.25rem;padding:0.75rem;text-align:center">
      <div class="font-mono" style="font-size:0.5625rem;color:#a3a3a3;margin-bottom:0.25rem">活跃信念</div>
      <div id="belief-count" style="font-size:1.5rem;font-weight:700;color:#2563eb">—</div>
    </div>
  </div>

  <div style="margin-bottom:0.5rem">
    <h2 class="font-mono" style="font-size:0.75rem;font-weight:600;color:#525252;text-transform:uppercase;letter-spacing:0.05em;margin:0">活跃信念</h2>
  </div>
  <div id="belief-list"></div>

  <div id="updates-section" style="display:none;margin-top:1.5rem">
    <div style="margin-bottom:0.5rem">
      <h2 class="font-mono" style="font-size:0.75rem;font-weight:600;color:#525252;text-transform:uppercase;letter-spacing:0.05em;margin:0">近期更新</h2>
    </div>
    <div id="updates-list"></div>
  </div>

  <div style="margin-top:2rem;padding-top:0.75rem;border-top:1px solid #e5e5e5;display:flex;gap:1rem;font-family:'JetBrains Mono',monospace;font-size:0.625rem">
    <a href="/research" style="color:#525252">← Research</a>
    <a href="/" style="color:#525252">← Dashboard</a>
  </div>
</BaseLayout>

<script>
async function loadMemoryData() {
  try {
    const resp = await fetch('/data/belief_db.json');
    if (!resp.ok) throw new Error('Not found');
    const data = await resp.json();

    document.getElementById('snapshot-date').textContent = data.snapshot_date || '—';
    document.getElementById('support-count').textContent = data.total_support || 0;
    document.getElementById('challenge-count').textContent = data.total_challenge || 0;
    document.getElementById('contradiction-count').textContent = data.contradictions_detected || 0;
    document.getElementById('belief-count').textContent = (data.beliefs || []).length;

    const list = document.getElementById('belief-list');
    if (data.beliefs && data.beliefs.length > 0) {
      list.innerHTML = data.beliefs.map(b => {
        const color = b.confidence >= 7 ? '#16a34a' : b.confidence >= 5 ? '#ca8a04' : '#a3a3a3';
        return `<div style="display:flex;align-items:center;padding:0.75rem 0;border-bottom:1px solid #e5e5e5">
          <div class="font-mono" style="min-width:3ch;font-weight:700;font-size:0.875rem;color:${color}">${b.confidence}</div>
          <div style="flex:1;margin-left:0.75rem">
            <div style="font-size:0.8125rem;color:#171717">${b.text}</div>
            <div style="font-size:0.625rem;color:#a3a3a3;margin-top:0.125rem" class="font-mono">${b.category || '—'} · ${(b.evidence_ids || []).length} 条证据</div>
          </div>
        </div>`;
      }).join('');
    } else {
      list.innerHTML = '<div class="font-mono" style="text-align:center;padding:2rem 0;color:#a3a3a3;font-size:0.8125rem">暂无信念数据。</div>';
    }

    if (data.recent_updates && data.recent_updates.length > 0) {
      document.getElementById('updates-section').style.display = 'block';
      document.getElementById('updates-list').innerHTML = data.recent_updates.slice(0,10).map(u => {
        const isPositive = u.delta > 0;
        const color = isPositive ? '#16a34a' : '#dc2626';
        const badge = u.is_contradiction ? '<span class="font-mono" style="font-size:0.5625rem;color:#dc2626;border:1px solid #dc2626;padding:0.0625rem 0.25rem;border-radius:0.125rem;margin-left:0.5rem">⬡ 矛盾</span>' : '';
        return `<div style="display:flex;align-items:center;padding:0.5rem 0;border-bottom:1px solid #f5f5f5">
          <span class="font-mono" style="font-size:0.75rem;font-weight:700;color:${color}">${isPositive ? '+' + u.delta : u.delta}</span>
          <span style="font-size:0.75rem;color:#525252;margin-left:0.75rem;flex:1">${u.belief_id}: ${u.reasoning}${badge}</span>
        </div>`;
      }).join('');
    }
  } catch {
    document.getElementById('snapshot-date').textContent = '数据不可用';
    document.getElementById('belief-list').innerHTML = '<div class="font-mono" style="text-align:center;padding:2rem 0;color:#a3a3a3;font-size:0.8125rem">管线运行后将在此处显示认知数据。</div>';
  }
}
loadMemoryData();
</script>
