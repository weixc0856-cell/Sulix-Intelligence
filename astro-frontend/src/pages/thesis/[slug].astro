---
import BaseLayout from '../../layouts/base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const theses = await getCollection('thesis');
  return theses.map(thesis => ({
    params: { slug: thesis.data.slug },
    props: { thesis },
  }));
}

const { thesis } = Astro.props;
const { Content } = await render(thesis);
---

<BaseLayout title={thesis.data.title} description={thesis.data.summary}>
  <div style="margin-bottom:1rem;padding-bottom:0.5rem;border-bottom:2px solid #171717">
    <div class="font-mono" style="display:flex;align-items:center;gap:0.75rem;font-size:0.75rem;color:#a3a3a3;margin-bottom:0.5rem">
      <span style="font-weight:600">{thesis.data.date}</span>
      <span style="font-weight:700">{thesis.data.status}</span>
    </div>
    <h1 class="font-mono" style="font-size:1.25rem;font-weight:700;color:#171717;margin:0">{thesis.data.title}</h1>
    {thesis.data.summary && <p style="font-size:0.8125rem;color:#525252;margin-top:0.375rem">{thesis.data.summary}</p>}
  </div>

  <div style="display:flex;gap:1rem;margin-bottom:1.5rem;font-size:0.75rem;color:#525252">
    <span class="font-mono">证据: {thesis.data.evidence_count}</span>
    {thesis.data.support_count !== undefined && <span class="font-mono" style="color:#16a34a">支持: {thesis.data.support_count}</span>}
    {thesis.data.challenge_count !== undefined && <span class="font-mono" style="color:#dc2626">挑战: {thesis.data.challenge_count}</span>}
  </div>

  <article style="font-size:0.875rem;line-height:1.6;color:#171717;max-width:48rem">
    <Content />
  </article>
</BaseLayout>
