---
import BaseLayout from '../layouts/base.astro';
import SignalRow from '../components/SignalRow.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const published = allPosts
  .filter(p => p.data.status === 'published')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Dashboard | Sulix.Intel" description="Daily Geopolitical Tech Intelligence Briefing">
  <div class="flex items-baseline justify-between border-b-2 border-neutral-950" style="margin-bottom:0.75rem;padding-bottom:0.5rem">
    <h1 class="font-mono font-bold text-neutral-900" style="font-size:1.25rem;margin:0">今日信号</h1>
    <span class="font-mono text-xs text-neutral-400">{published.length} 条</span>
  </div>

  {published.length > 0 ? (
    <div>
      {published.map(post => (
        <SignalRow
          title={post.data.title}
          date={post.data.date}
          svi={post.data.svi}
          colorTag={post.data.color_tag}
          isPremium={post.data.is_premium}
          slug={post.data.slug}
          summary={post.data.summary}
          tags={post.data.tags}
        />
      ))}
    </div>
  ) : (
    <div class="font-mono text-center text-neutral-400" style="padding:3rem 0;font-size:0.875rem">
      No significant signals today.
    </div>
  )}
</BaseLayout>
