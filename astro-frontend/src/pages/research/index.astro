---
import BaseLayout from '../../layouts/base.astro';
import { getCollection } from 'astro:content';

const reports = await getCollection('reports');
const published = reports
  .filter(r => r.data.status === 'published')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function tierColor(tier: string) {
  return tier === 'enterprise' ? '#ea580c' : '#2563eb';
}
function tierLabel(tier: string) {
  return tier === 'enterprise' ? '🔶 Enterprise' : tier === 'premium' ? '🔒 Premium' : '🆓 Free';
}
---

<BaseLayout title="Research | Sulix.Intel" description="Premium research reports on AI, technology, and market trends">
  <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:0.75rem;padding-bottom:0.5rem;border-bottom:2px solid #171717">
    <h1 class="font-mono" style="font-size:1.25rem;font-weight:700;color:#171717;margin:0">研究报告</h1>
    <span class="font-mono" style="font-size:0.6875rem;color:#a3a3a3">{published.length} 份</span>
  </div>

  {published.length > 0 ? (
    <div>
      {published.map(report => (
        <a href={`/research/${report.data.slug}`} style="display:block;padding:1rem 0;border-bottom:1px solid #e5e5e5;text-decoration:none">
          <div style="display:flex;align-items:flex-start;justify-content:space-between">
            <div style="flex:1">
              <div class="font-mono" style="font-size:0.75rem;color:#a3a3a3;margin-bottom:0.25rem">{report.data.date}</div>
              <h2 style="font-size:1rem;font-weight:600;color:#171717;margin:0 0 0.25rem">{report.data.title}</h2>
              {report.data.subtitle && <p style="font-size:0.8125rem;color:#525252;margin:0 0 0.375rem">{report.data.subtitle}</p>}
              <p style="font-size:0.75rem;color:#737373;margin:0;line-height:1.5">{report.data.summary}</p>
              <div style="display:flex;gap:0.5rem;margin-top:0.5rem">
                {report.data.pages && <span class="font-mono" style="font-size:0.625rem;color:#a3a3a3">{report.data.pages} 页</span>}
                {report.data.tags && report.data.tags.slice(0,3).map(tag => (
                  <span style="font-size:0.625rem;color:#a3a3a3;background:#f5f5f5;padding:0.0625rem 0.375rem;border-radius:0.125rem">{tag}</span>
                ))}
              </div>
            </div>
            <div style="text-align:right;margin-left:1rem;flex-shrink:0">
              <div style="font-size:1.125rem;font-weight:700;color:#171717">${report.data.price_usd}</div>
              <div class="font-mono" style={`font-size:0.625rem;color:${tierColor(report.data.tier)};margin-top:0.25rem`}>{tierLabel(report.data.tier)}</div>
            </div>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="font-mono" style="text-align:center;padding:3rem 0;color:#a3a3a3;font-size:0.875rem">
      No research reports yet.
    </div>
  )}
</BaseLayout>
