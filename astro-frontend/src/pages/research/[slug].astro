---
import BaseLayout from '../../layouts/base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map(report => ({
    params: { slug: report.data.slug },
    props: { report },
  }));
}

const { report } = Astro.props;
let contentHtml = '';
try {
  const { Content } = await render(report);
  contentHtml = Content.toString();
} catch {
  contentHtml = '';
}

const tierColor = report.data.tier === 'enterprise' ? '#ea580c' : report.data.tier === 'premium' ? '#2563eb' : '#16a34a';

const isPremium = report.data.tier !== 'free';
const hasSample = report.data.has_sample;
---

<BaseLayout title={`${report.data.title} | Sulix.Intel`} description={report.data.summary}>
  <div style="margin-bottom:1rem;padding-bottom:0.5rem;border-bottom:2px solid #171717">
    <h1 class="font-mono" style="font-size:1.25rem;font-weight:700;color:#171717;margin:0">{report.data.title}</h1>
    {report.data.subtitle && <p style="font-size:0.9375rem;color:#525252;margin-top:0.25rem;font-style:italic">{report.data.subtitle}</p>}
    <div class="font-mono" style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-top:0.5rem;font-size:0.75rem;color:#a3a3a3">
      <span>{report.data.date}</span>
      <span>${report.data.price_usd}</span>
      {report.data.pages && <span>{report.data.pages} 页</span>}
      {report.data.word_count && <span>~{report.data.word_count} 字</span>}
      <span style={`color:${tierColor}`}>{report.data.tier.toUpperCase()}</span>
    </div>
    {report.data.tags && (
      <div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-top:0.5rem">
        {report.data.tags.map(tag => (
          <span style="font-size:0.625rem;color:#525252;background:#f5f5f5;padding:0.0625rem 0.375rem;border-radius:0.125rem">{tag}</span>
        ))}
      </div>
    )}
  </div>

  <!-- 购买/预览按钮 -->
  <div style="display:flex;gap:0.75rem;margin-bottom:1.5rem">
    {report.data.buy_url && (
      <a href={report.data.buy_url} target="_blank" style="display:inline-block;background-color:#e3120b;color:#fff;font-family:'JetBrains Mono',monospace;font-size:0.75rem;font-weight:600;padding:0.5rem 1rem;border-radius:0.125rem;text-transform:uppercase;letter-spacing:0.05em;text-decoration:none">
        🛒 购买完整版 ${report.data.price_usd}
      </a>
    )}
    {hasSample && (
      <a href={`/research/${report.data.slug}/sample`} style="display:inline-block;border:1px solid #171717;color:#171717;font-family:'JetBrains Mono',monospace;font-size:0.75rem;font-weight:600;padding:0.5rem 1rem;border-radius:0.125rem;text-transform:uppercase;letter-spacing:0.05em;text-decoration:none">
        🔍 预览样本
      </a>
    )}
  </div>

  <!-- 报告正文：premium 内容物理截断 -->
  <div style="font-size:0.875rem;line-height:1.6;color:#171717;max-width:48rem">
    {contentHtml ? (
      <Fragment set:html={contentHtml} />
    ) : (
      <div class="font-mono" style="color:#a3a3a3;padding:1rem 0;font-size:0.75rem">Loading content...</div>
    )}
  </div>

  <!-- Premium 内容仅显示标题 -->
  {isPremium && (
    <div style="margin-top:1.5rem;padding-top:1rem;border-top:1px solid #e5e5e5">
      <p class="font-mono" style="font-size:0.75rem;color:#525252;margin:0 0 0.5rem;font-weight:600">完整内容包含：</p>
      <ul class="font-mono" style="font-size:0.75rem;color:#a3a3a3;margin:0;padding-left:1.25rem;line-height:1.8">
        <li>Competitive Analysis 🔒</li>
        <li>Technology Trends 🔒</li>
        <li>Startup Landscape 🔒</li>
        <li>Forecast 2026-2028 🔒</li>
      </ul>
    </div>
  )}

  {report.data.sources && report.data.sources.length > 0 && (
    <div style="margin-top:2rem;padding-top:1rem;border-top:1px solid #e5e5e5">
      <p class="font-mono" style="font-size:0.625rem;color:#a3a3a3;font-weight:600;text-transform:uppercase;margin:0 0 0.375rem">📚 Sources</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.375rem">
        {report.data.sources.map(src => (
          <span class="font-mono" style="font-size:0.6875rem;color:#525252">{src}</span>
        ))}
      </div>
    </div>
  )}

  {report.data.author && (
    <div style="margin-top:1rem;padding-top:0.5rem;border-top:1px solid #e5e5e5">
      <p class="font-mono" style="font-size:0.625rem;color:#a3a3a3;margin:0">{report.data.author}</p>
    </div>
  )}
</BaseLayout>
