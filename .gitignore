# ==========================================
# Rust crate — sulix-engine 标准 .gitignore
# 只版本控制 src/ + 项目配置
# ==========================================

# ---- 编译产物 ----
/target/
*.pdb
/schemas/
crates/sulix-contract/schemas/

# ---- 本地配置（含 API Key, 路径映射） ----
/config.toml
/config.local.toml
*.env

# ---- 管线生成产物 ----
output/
/DailyBrief/
/content/
/data/
*.db
*.db-journal
*.db-wal
*.jsonl

# ---- Claude Code 工作文件 ----
/.claude/
.rustc_info.json

# ---- 设计/头脑风暴临时文件 ----
/.superpowers/

# ---- 文档派生产物（架构 ADR + specs 不受影响）----
/docs/meeting-notes/
/docs/research/

# ---- 代码分析产物 ----
/.codegraph/
/findings.json
.ocodeignore
/archive/findings.json
/archive/reviews/

# ---- 旧归档迁移遗留 ----
/archive/content-posts-legacy/

# ---- Cloudflare 本地开发 ----
.wrangler/

# ---- Cloudflare Agent（已迁移至独立仓库 D:\Project\CF_Agent）----
/agents/
/agents

# ---- 操作系统文件 ----
Thumbs.db
.DS_Store

# ---- Cloudflare Agents SDK（独立 npm 项目）----
# agents/ has its own .gitignore
